{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/check-polaris-imports.sh",
        "matcher": "Write|Edit|StrReplace",
        "timeout": 10
      }
    ],
    "beforeReadFile": [
      {
        "command": ".cursor/hooks/guard-large-json.sh",
        "timeout": 5
      }
    ]
  }
}
